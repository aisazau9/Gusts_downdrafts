   "outputs": [],
   "source": [
    "# Paths\n",
    "path_figs   = \"/g/data/up6/ai2733/Gusts_downdrafts/figures/Figures/\"\n",
    "path_arrays = \"/g/data/up6/ai2733/Gusts_downdrafts/data/arrays/\"\n",
    "\n",
    "name_cases1 = {\"CASE1\": \"a) Moree Aero\",\n",
    "\"CASE2_new\": \"b) Wagga Wagga\",\n",
    "\"CASE3_new\": \"c) Tamworth Airport\"}"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "89e904a9-6e57-48c7-a072-71e7c93cd3d1",
   "metadata": {},
   "source": [
    "## Read data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "040dc52a-42ad-4543-a70f-46e6c96d468e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "CASE1 d02 vars read\n",
      "CASE1 d03 vars read\n",
      "CASE2_new d02 vars read\n",
      "CASE2_new d03 vars read\n",
      "CASE3_new d02 vars read\n",
      "CASE3_new d03 vars read\n"
     ]
    }
   ],
   "source": [
    "cases = [\"CASE1\", \"CASE2_new\", \"CASE3_new\"]\n",
    "domains = [\"d02\", \"d03\"]\n",
    "\n",
    "# Read variables all dims\n",
    "vars_read = [\"wa\",\"QRAIN\", \"QGRAUP\", \"QVAPOR\", \"temp\", \"z\"] \n",
    "how_read = [\"All\"]*len(vars_read)\n",
    "vars_coarsen_all  = {}\n",
    "for case in cases:\n",
    "    for dom in domains:\n",
    "        for var, how in zip (vars_read,how_read):\n",
    "            key = f\"{var}_{how}_{case}_{dom}\"\n",
    "            file_coar = f'{path_arrays}/{case}_{dom}_{var}{how}_80kmAWS_coarsen_Alldims.npy'\n",
    "            # Coarsen grid 80 km from AWS\n",
    "            vars_coarsen_all[key]  = np.load(file_coar)\n",
    "                \n",
    "        print (f\"{case} {dom} vars read\")\n",
    "\n",
    "# Convert units\n",
    "for key in vars_coarsen_all.keys():\n",
    "    if \"QRAIN\" in key:\n",
    "        vars_coarsen_all[key] = 1000. * vars_coarsen_all[key]\n",
    "    if \"QGRAUP\" in key:\n",
    "        vars_coarsen_all[key] = 1000. * vars_coarsen_all[key]\n",
    "\n",
    "# Read mean profiles\n",
    "vars_read = [\"pressure\", \"height\"]\n",
    "prof_coarsen_all = {stage: {} for stage in [\"All\"]}\n",
    "for case in cases:\n",
    "    for dom in domains:\n",
    "        for var in vars_read:\n",
    "            key = f\"{var}_{case}_{dom}\"\n",
    "            file_coar = f'{path_arrays}/TimeProf_{case}_{dom}_{var}_80kmAWS_coarsen.npy' \n",
    "            time_prof_coarsen_all = np.load(file_coar)\n",
    "            prof_coarsen_all[\"All\"][key] = time_prof_coarsen_all.mean(axis = 0)\n",
    "\n",
    "# Times\n",
    "times_cases = {}\n",
    "for case in cases:\n",
    "    times_cases[case] =  np.load(f\"{path_arrays}/Times_{case}.npy\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b7d5aa96-c9de-4d8c-bb54-28ce9b444c68",
   "metadata": {},
   "source": [
    "## Calculate MSE"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "43176dcb-0a73-43c3-9321-05833f2c7a05",
   "metadata": {},
   "outputs": [],
   "source": [
    "mse_all = {}\n",
    "for case in cases:\n",
    "    for dom in domains:\n",
    "        # Now calculate new variables with metpy\n",
    "        QVAPOR_arr = vars_coarsen_all[f\"QVAPOR_All_{case}_{dom}\"]* units(\"kg/kg\")\n",
    "        tk_array   = vars_coarsen_all[f\"temp_All_{case}_{dom}\"]* units.kelvin\n",
    "        height_arr = vars_coarsen_all[f\"z_All_{case}_{dom}\"]* units.meter\n",
    "        \n",
    "        sh_arr   = mpcalc.specific_humidity_from_mixing_ratio(mixing_ratio = QVAPOR_arr).to(\"kg/kg\")\n",
    "        mse_arr   = mpcalc.moist_static_energy(height = height_arr,\n",
    "                                               temperature =  tk_array, \n",
    "                                               specific_humidity = sh_arr).magnitude\n",
    "        mse_all[f\"{case}_{dom}\"] = mse_arr"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "89028996-8d59-4a24-b73c-f433cfbe5e05",
   "metadata": {},
   "source": [
    "## Figure 11: Plot differences (1 km - 200 m) for multiple variables"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "304cf8cd-2d68-4eef-878d-7fcbdaf81036",
   "metadata": {},
   "outputs": [],
   "source": [
    "def plot_diff_multiple_vars_thresholds(vars_list, thresholds_list, case, names_var, names_var2, units_var, labels_row):\n",
    "    \"\"\"\n",
    "    Plot differences (1 km - 200 m) for multiple variables in rows,\n",
    "    with variable-specific thresholds for columns.\n",
    "\n",
    "    Parameters:\n",
    "        vars_list: list of variable names (strings)\n",
    "        thresholds_list: list of lists of thresholds for each variable\n",
    "        case: case identifier (string)\n",
    "        names_var: list of names for titles\n",
    "        names_var2: list of names for colorbars\n",
    "        units_var: list of units for each variable\n",
    "        label_: figure label (left side)\n",
    "    \"\"\"\n",
    "    n_rows = len(vars_list)\n",
    "    n_cols = max(len(thr) for thr in thresholds_list)  # max columns across variables\n",
    "    \n",
    "    fig, axes = plt.subplots(n_rows, n_cols, figsize=(7*n_cols, 5*n_rows), sharey=True, sharex=True)\n",
    "    \n",
    "    # Ensure axes is 2D\n",
    "    if n_rows == 1:\n",
    "        axes = np.array([axes])\n",
    "    if n_cols == 1:\n",
    "        axes = axes[:, np.newaxis]\n",
    "    \n",
    "    n_cbar_levels = 15\n",
    "\n",
    "    for i, var in enumerate(vars_list):\n",
    "        thresholds = thresholds_list[i]\n",
    "        for j, thr in enumerate(thresholds):\n",
    "            \n",
    "            # --- Load 1km and 200m data ---\n",
    "            if var == \"wa_down\":\n",
    "                var_1km = np.abs(np.where(vars_coarsen_all[f'wa_All_{case}_d02'] <= thr,\n",
    "                                   vars_coarsen_all[f'wa_All_{case}_d02'], np.NaN))\n",
    "                var_200m = np.abs(np.where(vars_coarsen_all[f'wa_All_{case}_d03'] <= thr,\n",
    "                                    vars_coarsen_all[f'wa_All_{case}_d03'], np.NaN))\n",
    "            else:\n",
    "                var_1km = np.where(vars_coarsen_all[f'{var}_All_{case}_d02'] >= thr,\n",
    "                                   vars_coarsen_all[f'{var}_All_{case}_d02'], np.NaN)\n",
    "                var_200m = np.where(vars_coarsen_all[f'{var}_All_{case}_d03'] >= thr,\n",
    "                                    vars_coarsen_all[f'{var}_All_{case}_d03'], np.NaN)\n",
    "            \n",
    "            var_1km = np.nanmean(var_1km, axis=(2,3))\n",
    "            var_200m = np.nanmean(var_200m, axis=(2,3))\n",
    "            \n",
    "            # --- Compute difference ---\n",
    "            var_diff = np.abs(var_1km) - np.abs(var_200m)\n",
    "            mask_nan = np.isnan(var_1km) | np.isnan(var_200m)\n",
    "            var_diff[mask_nan] = np.nan\n",
    "\n",
    "            # --- Detect NaNs for stippling ---\n",
    "            nan_1km_valid_200m = np.isnan(var_1km) & ~np.isnan(var_200m)\n",
    "            nan_200m_valid_1km = ~np.isnan(var_1km) & np.isnan(var_200m)\n",
    "\n",
    "            # --- Normalization and colormap ---\n",
    "            diff_vmax = np.nanmax(np.abs(var_diff))\n",
    "            diff_levels = np.linspace(-diff_vmax, diff_vmax, n_cbar_levels)\n",
    "            diff_norm = BoundaryNorm(boundaries=diff_levels, ncolors=n_cbar_levels-1)\n",
    "            diff_cmap = plt.get_cmap('bwr', n_cbar_levels-1)\n",
    "\n",
    "            # --- Axes setup ---\n",
    "            pressure = prof_coarsen_all[\"All\"][f\"pressure_{case}_d02\"]\n",
    "            time = np.arange(var_1km.shape[0])\n",
    "            times = pd.to_datetime(times_cases[case])\n",
    "            Time, Pressure = np.meshgrid(time, pressure)\n",
    "            \n",
    "            ax = axes[i, j]\n",
    "            im = ax.pcolormesh(Time, Pressure, var_diff.T, cmap=diff_cmap, norm=diff_norm)\n",
    "            ax.set_ylim(Pressure.max(), Pressure.min())\n",
    "            if i == n_rows - 1: \n",
    "                ax.set_xlabel('Time')\n",
    "            if j == 0:\n",
    "                ax.set_ylabel('Pressure [hPa]')\n",
    "\n",
    "            # --- Title ---\n",
    "            ax.set_title(f'{names_var[i]} {thr} {units_var[i]}', fontweight=\"bold\")\n",
    "\n",
    "            # --- Stippling ---\n",
    "            if np.any(nan_1km_valid_200m):\n",
    "                y_stip, x_stip = np.where(nan_1km_valid_200m.T)\n",
    "                if len(x_stip) > 5000:\n",
    "                    idx = np.random.choice(len(x_stip), 5000, replace=False)\n",
    "                    x_stip, y_stip = x_stip[idx], y_stip[idx]\n",
    "                ax.scatter(Time[0, x_stip], Pressure[y_stip, 0], s=8, c='k', marker='.', alpha=0.5)\n",
    "            if np.any(nan_200m_valid_1km):\n",
    "                y_stip, x_stip = np.where(nan_200m_valid_1km.T)\n",
    "                if len(x_stip) > 5000:\n",
    "                    idx = np.random.choice(len(x_stip), 5000, replace=False)\n",
    "                    x_stip, y_stip = x_stip[idx], y_stip[idx]\n",
    "                ax.scatter(Time[0, x_stip], Pressure[y_stip, 0], s=8, c='green', marker='.', alpha=0.5)\n",
    "\n",
    "            # --- Time labels ---\n",
    "            if i == n_rows - 1:  # last row\n",
    "                num_xticks = 6\n",
    "                xtick_indices = np.linspace(0, len(times)-1, num_xticks, dtype=int)\n",
    "                time_labels = [times[k].strftime('%H:%M') for k in xtick_indices]\n",
    "                ax.set_xticks(xtick_indices)\n",
    "                ax.set_xticklabels(time_labels, rotation=45)\n",
    "            else:\n",
    "                ax.set_xticklabels([])  # hide x labels\n",
    "\n",
    "            # --- Colorbar ---\n",
    "            fig.colorbar(im, ax=ax, label=r'$\\Delta$' + names_var2[i])\n",
    "\n",
    "            # Add row label on the left\n",
    "            axes[i, 0].text(-0.22, 1.15, labels_row[i], fontsize=30, fontweight='bold', \n",
    "                    va='center', ha='left', transform=axes[i, 0].transAxes)\n",
    "    \n",
    "    # Colormap handle (as a rectangle)\n",
    "    cmap_patch = mpatches.Patch(color='lightgray', label='Difference (1 km - coarsened 200 m)')  # just a placeholder\n",
    "    \n",
    "    # Stippling handles\n",
    "    black_dot = Line2D([0], [0], marker='.', color='w', markerfacecolor='k', markersize=40, label='200 m only')\n",
    "    green_dot = Line2D([0], [0], marker='.', color='w', markerfacecolor='green', markersize=40, label='1 km only')\n",
    "\n",
    "    fig.legend(handles=[cmap_patch, black_dot, green_dot],\n",
    "           loc='upper center',\n",
    "           bbox_to_anchor=(0.5, 1.02),  # slightly higher than default 1.05\n",
    "           ncol=3, fontsize=30, frameon=False)\n",
    "    \n",
    "    plt.subplots_adjust(left=None, right=None, bottom=None, top=None, wspace=0.01, hspace=0.4)\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(f\"{path_figs}/Figure11.png\", dpi = 300, bbox_inches = \"tight\")\n",
    "    plt.show()\n"
   ]
  },
